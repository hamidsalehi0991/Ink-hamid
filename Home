<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hamid Tattoo — Hamburg</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
<style>

/* ===== RESET & BASE ===== */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
–black: #111111;
–dark: #1a1a1a;
–mid: #2a2a2a;
–cream: #f4f0ea;
–white: #ffffff;
–gold: #c8a96e;
–gray: #888888;
–light-gray: #cccccc;
–border: rgba(255,255,255,0.1);
}

html { scroll-behavior: smooth; }

body {
background: var(–black);
color: var(–white);
font-family: ‘Lato’, sans-serif;
font-weight: 300;
font-size: 16px;
line-height: 1.7;
}

a { color: inherit; text-decoration: none; }
img { max-width: 100%; display: block; }

/* ===== TOP BAR ===== */
.top-bar {
background: #000;
padding: 8px 0;
text-align: center;
font-size: 12px;
letter-spacing: 2px;
text-transform: uppercase;
color: var(–gray);
border-bottom: 1px solid var(–border);
}
.top-bar a { color: var(–gold); margin: 0 8px; }
.top-bar a:hover { text-decoration: underline; }

/* ===== HEADER / NAV ===== */
header {
position: fixed;
top: 37px; left: 0; right: 0;
z-index: 1000;
background: rgba(10,10,10,0.97);
border-bottom: 1px solid var(–border);
}
.header-inner {
max-width: 1200px;
margin: 0 auto;
padding: 0 40px;
display: flex;
align-items: center;
justify-content: space-between;
height: 80px;
}
.logo-wrap {
display: flex;
align-items: center;
gap: 12px;
}
.logo-text-wrap {
display: flex;
flex-direction: column;
}
.logo-main {
font-family: ‘Playfair Display’, serif;
font-size: 22px;
font-weight: 700;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–white);
line-height: 1;
}
.logo-sub {
font-size: 9px;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–gold);
margin-top: 3px;
}

nav ul {
list-style: none;
display: flex;
gap: 0;
}
nav ul li a {
display: block;
padding: 28px 18px;
font-size: 11px;
letter-spacing: 2px;
text-transform: uppercase;
color: var(–light-gray);
transition: color 0.2s, border-color 0.2s;
border-bottom: 2px solid transparent;
}
nav ul li a:hover {
color: var(–white);
border-bottom-color: var(–gold);
}

.header-right {
display: flex;
align-items: center;
gap: 20px;
}
.header-phone {
font-size: 13px;
letter-spacing: 1px;
color: var(–gold);
}
.header-book {
font-size: 10px;
letter-spacing: 2px;
text-transform: uppercase;
padding: 10px 20px;
border: 1px solid var(–gold);
color: var(–gold);
transition: background 0.2s, color 0.2s;
}
.header-book:hover { background: var(–gold); color: var(–black); }
.hamburger { display: none; }

/* ===== HERO ===== */
.hero {
min-height: 100vh;
display: flex;
align-items: center;
justify-content: center;
text-align: center;
position: relative;
overflow: hidden;
padding: 140px 40px 80px;
}
.hero-bg {
position: absolute; inset: 0;
background: #111;
/* To add your own photo: background-image: url(‘hero.jpg’); background-size: cover; background-position: center; */
}
.hero-bg::before {
content: ‘’;
position: absolute; inset: 0;
background: linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0.7) 100%);
z-index: 1;
}
.hero-bg::after {
content: ‘’;
position: absolute; inset: 0;
background-image: url(“data:image/svg+xml,%3Csvg width=‘60’ height=‘60’ viewBox=‘0 0 60 60’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cg fill=‘none’%3E%3Cg fill=’%23ffffff’ fill-opacity=‘0.015’%3E%3Cpath d=‘M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z’/%3E%3C/g%3E%3C/g%3E%3C/svg%3E”);
z-index: 1;
}
.hero-content {
position: relative;
z-index: 2;
max-width: 820px;
}
.hero-eyebrow {
display: block;
font-size: 11px;
letter-spacing: 5px;
text-transform: uppercase;
color: var(–gold);
margin-bottom: 24px;
}
.hero-title {
font-family: ‘Playfair Display’, serif;
font-size: clamp(36px, 6vw, 68px);
font-weight: 400;
line-height: 1.2;
margin-bottom: 24px;
color: var(–white);
}
.hero-title em { font-style: italic; color: var(–gold); }
.hero-divider {
width: 60px; height: 1px;
background: var(–gold);
margin: 28px auto;
}
.hero-text {
font-size: 16px;
line-height: 1.9;
color: var(–light-gray);
max-width: 600px;
margin: 0 auto 36px;
}
.hero-text strong { color: var(–white); font-weight: 400; }
.hero-text a { color: var(–gold); }
.btn-outline {
display: inline-block;
padding: 16px 44px;
background: transparent;
border: 1px solid var(–gold);
color: var(–gold);
font-size: 11px;
letter-spacing: 3px;
text-transform: uppercase;
transition: background 0.3s, color 0.3s;
}
.btn-outline:hover { background: var(–gold); color: var(–black); }

/* ===== INTRO STRIP ===== */
.intro-strip {
background: var(–dark);
border-top: 1px solid var(–border);
border-bottom: 1px solid var(–border);
padding: 60px 40px;
text-align: center;
}
.intro-strip p {
font-size: 17px;
line-height: 2;
color: var(–light-gray);
max-width: 720px;
margin: 0 auto;
}
.intro-strip strong { color: var(–white); font-weight: 400; }
.intro-strip a { color: var(–gold); }
.intro-strip a:hover { text-decoration: underline; }

/* ===== SECTIONS ===== */
section { padding: 90px 40px; }
.section-inner { max-width: 1100px; margin: 0 auto; }
.section-label {
font-size: 11px;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–gold);
margin-bottom: 12px;
display: block;
}
.section-title {
font-family: ‘Playfair Display’, serif;
font-size: clamp(28px, 4vw, 44px);
font-weight: 400;
color: var(–white);
line-height: 1.2;
}
.section-title em { font-style: italic; color: var(–gold); }
.section-divider {
width: 50px; height: 1px;
background: var(–gold);
margin: 20px 0 30px;
}
.section-divider.center { margin: 20px auto 30px; }
.section-text {
font-size: 15px;
line-height: 1.9;
color: var(–light-gray);
max-width: 680px;
}

/* ===== ABOUT ===== */
.about-section { background: var(–black); }
.about-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 70px;
align-items: start;
}
.about-img {
width: 100%;
aspect-ratio: 4/5;
background: var(–mid);
display: flex;
align-items: center;
justify-content: center;
flex-direction: column;
gap: 14px;
}
.about-img svg { opacity: 0.2; }
.about-img span {
font-size: 10px;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–gray);
}
.about-img-caption {
font-size: 11px;
letter-spacing: 2px;
text-transform: uppercase;
color: var(–gray);
margin-top: 14px;
text-align: center;
}
.quote-block {
background: var(–dark);
border-left: 3px solid var(–gold);
padding: 28px 32px;
margin: 36px 0;
}
.quote-block blockquote {
font-family: ‘Playfair Display’, serif;
font-style: italic;
font-size: 17px;
line-height: 1.7;
color: var(–cream);
margin-bottom: 12px;
}
.quote-block cite {
font-size: 11px;
letter-spacing: 2px;
text-transform: uppercase;
color: var(–gold);
font-style: normal;
}

/* ===== GALLERY ===== */
.work-section { background: var(–dark); }
.gallery-grid {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 3px;
margin-top: 50px;
}
.gallery-item {
aspect-ratio: 1;
background: var(–mid);
position: relative;
overflow: hidden;
cursor: pointer;
}
.gallery-item.wide { grid-column: span 2; aspect-ratio: 2/1; }
.gallery-placeholder {
position: absolute; inset: 0;
display: flex; align-items: center; justify-content: center;
flex-direction: column; gap: 10px;
background: linear-gradient(145deg, #222, #111);
transition: transform 0.5s ease;
}
.gallery-item:hover .gallery-placeholder { transform: scale(1.04); }
.gallery-placeholder svg { opacity: 0.15; }
.gallery-placeholder span {
font-size: 10px;
letter-spacing: 2px;
text-transform: uppercase;
color: var(–gray);
}
.gallery-hover {
position: absolute; inset: 0;
background: rgba(0,0,0,0.75);
display: flex; align-items: center; justify-content: center;
opacity: 0;
transition: opacity 0.3s;
}
.gallery-item:hover .gallery-hover { opacity: 1; }
.gallery-hover span {
font-family: ‘Playfair Display’, serif;
font-style: italic;
font-size: 16px;
color: var(–gold);
letter-spacing: 2px;
}

/* ===== SERVICES ===== */
.services-section { background: var(–black); }
.services-grid {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 1px;
background: var(–border);
margin-top: 50px;
}
.service-item {
background: var(–black);
padding: 44px 36px;
border-top: 3px solid transparent;
transition: border-color 0.3s;
}
.service-item:hover { border-color: var(–gold); }
.service-icon {
width: 44px; height: 44px;
border: 1px solid rgba(200,169,110,0.3);
display: flex; align-items: center; justify-content: center;
margin-bottom: 24px;
}
.service-name {
font-family: ‘Playfair Display’, serif;
font-size: 20px;
font-weight: 400;
margin-bottom: 14px;
color: var(–white);
}
.service-desc {
font-size: 14px;
line-height: 1.8;
color: var(–gray);
}

/* ===== TESTIMONIALS ===== */
.testimonials-section { background: var(–dark); text-align: center; }
.testimonials-grid {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 30px;
margin-top: 50px;
text-align: left;
}
.testimonial-card {
background: var(–black);
padding: 34px 28px;
border: 1px solid var(–border);
}
.testimonial-stars { color: var(–gold); font-size: 14px; letter-spacing: 3px; margin-bottom: 16px; }
.testimonial-text {
font-family: ‘Playfair Display’, serif;
font-style: italic;
font-size: 15px;
line-height: 1.8;
color: var(–cream);
margin-bottom: 18px;
}
.testimonial-author {
font-size: 11px;
letter-spacing: 2px;
text-transform: uppercase;
color: var(–gold);
}

/* ===== CONTACT ===== */
.contact-section { background: var(–black); }
.contact-grid {
display: grid;
grid-template-columns: 1fr 1.4fr;
gap: 70px;
align-items: start;
}
.contact-info-block h3 {
font-family: ‘Playfair Display’, serif;
font-size: 16px;
font-weight: 400;
color: var(–white);
margin: 24px 0 6px;
}
.contact-info-block h3:first-child { margin-top: 32px; }
.contact-info-block p, .contact-info-block li {
font-size: 14px;
color: var(–gray);
line-height: 1.9;
list-style: none;
}
.contact-info-block a { color: var(–gold); }
.contact-info-block a:hover { text-decoration: underline; }
.hours-table { margin-top: 6px; }
.hours-row {
display: flex;
justify-content: space-between;
font-size: 14px;
color: var(–gray);
padding: 5px 0;
border-bottom: 1px solid var(–border);
}
.hours-row:last-child { border-bottom: none; }
.hours-row .day { color: var(–light-gray); }
.social-row {
display: flex;
gap: 10px;
margin-top: 20px;
flex-wrap: wrap;
}
.social-btn {
display: flex; align-items: center; gap: 8px;
padding: 10px 18px;
border: 1px solid var(–border);
font-size: 11px;
letter-spacing: 2px;
text-transform: uppercase;
color: var(–light-gray);
transition: border-color 0.2s, color 0.2s;
}
.social-btn:hover { border-color: var(–gold); color: var(–gold); }

/* FORM */
.contact-form {
background: var(–dark);
padding: 48px 44px;
border: 1px solid var(–border);
}
.contact-form h3 {
font-family: ‘Playfair Display’, serif;
font-size: 26px;
font-weight: 400;
margin-bottom: 8px;
}
.contact-form > p {
font-size: 13px;
color: var(–gray);
margin-bottom: 10px;
line-height: 1.7;
}
.form-note {
font-size: 12px;
color: var(–gray);
font-style: italic;
border-left: 2px solid var(–gold);
padding-left: 12px;
margin-bottom: 28px;
}
.field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 20px; }
.field label {
font-size: 10px;
letter-spacing: 2px;
text-transform: uppercase;
color: var(–gray);
}
.field input, .field select, .field textarea {
background: var(–black);
border: 1px solid var(–border);
color: var(–white);
font-family: ‘Lato’, sans-serif;
font-size: 15px;
font-weight: 300;
padding: 14px 16px;
outline: none;
width: 100%;
transition: border-color 0.2s;
appearance: none;
}
.field input:focus, .field select:focus, .field textarea:focus { border-color: var(–gold); }
.field input::placeholder, .field textarea::placeholder { color: #444; }
.field select option { background: var(–dark); }
.field textarea { min-height: 120px; resize: vertical; }
.btn-form {
width: 100%;
padding: 17px;
background: var(–gold);
color: var(–black);
font-family: ‘Lato’, sans-serif;
font-size: 11px;
font-weight: 700;
letter-spacing: 3px;
text-transform: uppercase;
border: none;
cursor: pointer;
margin-top: 6px;
transition: opacity 0.2s;
}
.btn-form:hover { opacity: 0.88; }

/* ===== FOOTER ===== */
footer { background: #080808; border-top: 1px solid var(–border); }
.footer-top {
max-width: 1100px;
margin: 0 auto;
padding: 60px 40px 40px;
display: grid;
grid-template-columns: 1.5fr 1fr 1fr;
gap: 50px;
}
.footer-brand-name {
font-family: ‘Playfair Display’, serif;
font-size: 22px;
font-weight: 700;
letter-spacing: 3px;
text-transform: uppercase;
}
.footer-brand-sub {
font-size: 10px;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–gold);
margin-top: 4px;
}
.footer-brand p {
font-size: 13px;
color: var(–gray);
line-height: 1.8;
max-width: 280px;
margin-top: 14px;
}
.footer-col h4 {
font-size: 10px;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–gold);
margin-bottom: 18px;
}
.footer-col ul { list-style: none; }
.footer-col ul li { margin-bottom: 10px; }
.footer-col ul li a { font-size: 13px; color: var(–gray); transition: color 0.2s; }
.footer-col ul li a:hover { color: var(–white); }
.footer-col li span { font-size: 13px; color: var(–gray); }
.footer-bottom {
border-top: 1px solid var(–border);
padding: 20px 40px;
max-width: 1100px;
margin: 0 auto;
display: flex;
justify-content: space-between;
align-items: center;
}
.footer-bottom p { font-size: 12px; color: var(–gray); letter-spacing: 1px; }

/* ===== RESPONSIVE ===== */
@media (max-width: 900px) {
.header-inner { padding: 0 20px; }
nav { display: none; }
.hamburger {
display: block;
background: none; border: none;
color: var(–white); font-size: 22px;
cursor: pointer; padding: 8px;
}
.header-right { display: none; }
section { padding: 60px 20px; }
.hero { padding: 140px 20px 60px; }
.about-grid, .contact-grid { grid-template-columns: 1fr; gap: 40px; }
.gallery-grid { grid-template-columns: 1fr 1fr; }
.gallery-item.wide { grid-column: span 2; }
.services-grid, .testimonials-grid { grid-template-columns: 1fr; }
.field-row { grid-template-columns: 1fr; }
.footer-top { grid-template-columns: 1fr; gap: 30px; }
.footer-bottom { flex-direction: column; gap: 8px; text-align: center; }
.contact-form { padding: 28px 20px; }
}
</style>

</head>
